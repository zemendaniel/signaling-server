# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/signaling-server.log

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Room behavior
ROOM_EXPIRE=300
MAX_MESSAGE_SIZE=4096
MAX_ROOM_GENERATION_ATTEMPTS=1000

# Optional relay integration
# RELAY_URL_BASE=https://your-relay-service.example.com
# RELAY_PUBLIC_HOST=relay.your-domain.example.com (or the IP address of your server)
# RELAY_KEY=your-relay-api-key

